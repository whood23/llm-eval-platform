# ──────────────────────────────────────────────────────────────────────────────
# llm-eval-platform configuration.
#
# Copy to `.env` (which is git-ignored) and edit. Every variable here maps to a
# field on `evalplatform.config.Settings` via the `EVAL_` prefix. The defaults run
# the whole platform offline with no API keys (provider=dummy), so `.env` is
# entirely optional until you switch to a real judge.
#
# NOTE: provider *API keys* (GEMINI_API_KEY, DEEPSEEK_API_KEY, ...) are read by
# litellm itself, NOT by the EVAL_* settings — they have no EVAL_ prefix.
# ──────────────────────────────────────────────────────────────────────────────

# ── provider / judge ───────────────────────────────────────────────────────────
# "dummy"  = offline deterministic provider (default; no keys, no network)
# "litellm" = real judge via litellm (needs:  pip install -e .[providers])
EVAL_PROVIDER=dummy

# litellm model id for the judge (ignored when EVAL_PROVIDER=dummy).
EVAL_JUDGE_MODEL=gemini/gemini-2.0-flash

# Bump whenever you change the judge prompt/rubric. It is part of the cache key,
# so changing it invalidates cached judgments and forces a re-judge.
EVAL_PROMPT_VERSION=v1

# Base URL for local / OpenAI-compatible endpoints (e.g. Ollama). Leave unset otherwise.
# EVAL_API_BASE=http://localhost:11434

# Judges should be near-deterministic.
EVAL_TEMPERATURE=0.0

# ── concurrency / reliability ────────────────────────────────────────────────
EVAL_MAX_CONCURRENCY=4        # parallel in-flight judge calls
EVAL_MAX_RETRIES=5            # retry attempts on transient provider errors
# EVAL_RPM_LIMIT=15           # requests-per-minute cap; unset = unlimited (Gemini free tier likes ~15)
EVAL_REQUEST_TIMEOUT=60       # per-call timeout, seconds

# ── caching / storage ──────────────────────────────────────────────────────────
EVAL_CACHE_ENABLED=true       # skip re-judging on a cache-key hit
# EVAL_DB_PATH=data/eval.db
# EVAL_DATA_DIR=data
# EVAL_REPORTS_DIR=reports

# ── stats defaults (consumed by the hand-coded stats layer) ─────────────────────
EVAL_BOOTSTRAP_RESAMPLES=10000
EVAL_CONFIDENCE=0.95
EVAL_SEED=0

# ════════════════════════════════════════════════════════════════════════════════
# Provider examples — uncomment ONE block and set the matching key/EVAL_PROVIDER.
# ════════════════════════════════════════════════════════════════════════════════

# ── Gemini (default judge; generous free tier) ──────────────────────────────────
# EVAL_PROVIDER=litellm
# EVAL_JUDGE_MODEL=gemini/gemini-2.0-flash
# GEMINI_API_KEY=your-gemini-key            # read by litellm

# ── Ollama (fully local, no key) ────────────────────────────────────────────────
# Requires a running Ollama daemon and a pulled model (`ollama pull qwen3:8b`).
# EVAL_PROVIDER=litellm
# EVAL_JUDGE_MODEL=ollama/qwen3:8b
# EVAL_API_BASE=http://localhost:11434

# ── DeepSeek ─────────────────────────────────────────────────────────────────────
# EVAL_PROVIDER=litellm
# EVAL_JUDGE_MODEL=deepseek/deepseek-chat
# DEEPSEEK_API_KEY=your-deepseek-key        # read by litellm
